<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Автосалон "Автографф"</title>
    <link rel="stylesheet" href="style.css"> 
</head>
<body>
    <div class="login-container">
        <h1>Автографф</h1>
        <p>Дилерский центр</p>
        <p>Введите вашу почту</p>

        <form id="loginForm" onsubmit="event.preventDefault(); userLogin();">
            <label>Ваш email</label>
            <input type="email" id="email" name="email" required>
            <label>Ваш пароль</label>
            <input type="password" id="password" name="password" required>
            <button type="submit">Войти</button>
            <p>
                <a href="main-head.html">На главную</a>
                <a href="registration.html">Регистрация</a>
                <a href="asorti-cars.html">Каталог</a>
            </p>
        </form>
        <a href="registration.html">Ещё не зарегистрированы? Зарегистрироваться</a> 
    </div>

    <script>
// ========== ЕСЛИ УЖЕ ЗАЛОГИНЕН ==========
//const token = localStorage.getItem('token');
//if (token) {
//    window.location.href = 'dashboard.html';
//}

// ========== КОНФИГ ==========
const API_URL = 'http://localhost:8080/api/v1/auth';

async function userLogin() {
    const email = document.getElementById("email").value.trim();
    const password = document.getElementById("password").value.trim();
    
    if (!email || !password) {
        alert("Пожалуйста, заполните все поля!!!");
        return;
    }
    
    if (!email.includes("@") || !email.includes(".")) {
        alert("Введите корректный email адрес");
        return;
    }
    
    if (password.length < 6) {
        alert("Пароль должен быть минимум 6 символов");
        return;
    }
    
    const submitBtn = document.querySelector("button");
    const oldText = submitBtn.innerHTML;
    submitBtn.disabled = true;
    submitBtn.innerHTML = "Подождите...";
    
    try {
        const response = await fetch(`${API_URL}/authenticate`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email, password })
        });
        
        const data = await response.json();
        
        if (!response.ok) {
            if (response.status == 401) throw new Error("Неверный email или пароль");
            if (response.status == 404) throw new Error("Сервер не найден");
            throw new Error(data.message || "Ошибка " + response.status);
        }
        
        if (data.data && data.data.token) {
            localStorage.setItem("token", data.data.token);
            localStorage.setItem("user", JSON.stringify(data.data.user || { email }));
            alert("Вход выполнен успешно!");
            window.location.href = "dashboard.html";
        } else {
            throw new Error("Сервер не отдал токен");
        }
        
    } catch (err) {
        console.error("Ошибка:", err);
        
        // ========== РЕЗЕРВНЫЙ ОТВЕТ (ДЕМО-РЕЖИМ) ==========
        if (email === "demo@autograf.ru" && password === "demo123") {
            localStorage.setItem("token", "demo_token_" + Date.now());
            localStorage.setItem("user", JSON.stringify({ email, username: "Демо-пользователь" }));
            alert("⚠️ Демо-режим (сервер недоступен)");
            window.location.href = "dashboard.html";
        } else {
            alert(err.message || "Ошибка соединения с сервером. Демо-аккаунт: demo@autograf.ru / demo123");
        }
    } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = oldText;
    }
}
    </script>
</body>
</html>
